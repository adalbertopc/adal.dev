---
import MainLayout from "../layouts/main-layout.astro";
import Section from "../components/section.astro";
import Entry from "../components/entry.astro";

const experience = [
  {
    title: "Ben & Frank",
    meta: "Frontend Developer",
    href: "https://www.benandfrank.com",
    period: "2022 — 24",
  },
  {
    title: "Team54",
    meta: "Shopify Developer",
    href: "https://www.linkedin.com/company/team54/",
    period: "2020 — 22",
  },
  {
    title: "Cefis",
    meta: "Software Engineer, freelance",
    href: "https://www.cefis.mx",
    period: "2022",
  },
  {
    title: "MightyWizards",
    meta: "Shopify Developer, freelance",
    href: "https://www.linkedin.com/company/mighty-wizards-technologies",
    period: "2021",
  },
];

const tools = [
  { title: "MacBook Pro", meta: "M3 Pro" },
  { title: "AirPods Max", meta: "everyday audio" },
  { title: "NuPhy Air V3", meta: "low-profile mechanical" },
  { title: "Logitech MX Master 3s", meta: "pointer" },
  { title: "Starlink", meta: "connectivity" },
];

const socials = [
  { label: "GitHub", href: "https://github.com/adalbertopc" },
  { label: "LinkedIn", href: "https://linkedin.com/in/adalberto-prado/" },
  { label: "X", href: "https://x.com/adalcodes" },
];
---

<MainLayout title="Software Engineer">
  <header>
    <h1 class="text-2xl font-semibold tracking-tight">Adalberto Prado</h1>
    <p class="mt-1 font-mono text-sm text-muted">Software Engineer</p>
    <p class="mt-6 max-w-md text-sm leading-relaxed text-muted">
      I build for <span class="text-fg">fintech</span> and <span class="text-fg"
        >e-commerce</span
      >, working mostly with React, Next.js and Python on scalable, secure
      systems. Currently at {" "}<a
        href="https://www.konfio.mx"
        target="_blank"
        rel="noopener noreferrer"
        class="text-fg decoration-line hover:decoration-fg hover:underline"
        >Konfío</a
      >.
    </p>
  </header>

  <Section label="Now">
    <Entry
      title="Konfío"
      meta="Software Engineer"
      href="https://www.konfio.mx"
      period="2024 — Now"
    />
    <p class="pt-1 text-sm leading-relaxed text-muted">
      Building user-onboarding for financial products — accessible React
      interfaces, resilient API endpoints and observability with Grafana,
      CloudWatch and New Relic.
    </p>
  </Section>

  <Section label="Work">
    {experience.map((job) => <Entry {...job} />)}
  </Section>

  <Section label="Tools">
    {tools.map((tool) => <Entry {...tool} />)}
  </Section>

  <Section label="Projects">
    <p class="py-1.5 text-sm text-muted">
      Soon <span class="font-mono text-faint">— in the works.</span>
    </p>
  </Section>

  <Section label="Education">
    <Entry
      title="Instituto Tecnológico de Sonora"
      meta="B.S. Software Engineering"
      href="https://www.itson.mx"
      period="2018 — 22"
    />
  </Section>

  <footer class="mt-20 border-t border-line pt-6">
    <nav class="flex flex-wrap gap-x-5 gap-y-2">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs text-muted transition-colors hover:text-fg"
          >
            {s.label}
          </a>
        ))
      }
    </nav>
  </footer>
</MainLayout>
