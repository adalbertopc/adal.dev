---
import "../styles/global.css";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Software Engineer",
  description = "Adalberto Prado — software engineer building for fintech and e-commerce with React, Next.js and Python.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={`Adalberto Prado — ${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>Adalberto Prado — {title}</title>
  </head>
  <body>
    <div class="mx-auto max-w-xl px-6 py-20 sm:py-28">
      <slot />
    </div>
  </body>
</html>
